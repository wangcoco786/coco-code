# ============================================================
# 环境变量配置模板
# 复制此文件为 .env.local 并填入真实值
# ============================================================

# Jira Server 地址（不含末尾斜杠）
JIRA_BASE_URL=https://jira.your-company.com

# Jira 鉴权（二选一）
# 方式 1：Basic Auth（Jira 6.x / Server 旧版本）
JIRA_USERNAME=your_jira_username
JIRA_PASSWORD=your_jira_password
# 方式 2：PAT（Jira 8.14+ / Data Center）
# JIRA_PAT=your_personal_access_token

# 企业微信群机器人 Webhook 地址
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# 默认 Jira Board ID（在 Board URL 中找到）
VITE_DEFAULT_BOARD_ID=1
